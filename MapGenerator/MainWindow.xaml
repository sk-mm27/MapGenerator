<Window x:Class="MapGenerator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MapGenerator"
        mc:Ignorable="d"
        Title="MapGenerator" 
        Height="600" 
        Width="900"        
        WindowStartupLocation="CenterScreen"     
        ResizeMode="NoResize"
        Background="AliceBlue">
    <Grid Margin="25,25,25,25">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="100*"/>
                <RowDefinition Height="10*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderBrush="Black" BorderThickness="15" Width="{Binding ActualHeight, RelativeSource={RelativeSource Self}}" >
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <Image x:Name="Image11" Grid.Row ="0" Grid.Column="0" MouseDown="RegenerationMapCell"/>
                    <Image x:Name="Image12" Grid.Row ="0" Grid.Column="1" MouseDown="RegenerationMapCell"/>
                    <Image x:Name="Image13" Grid.Row ="0" Grid.Column="2" MouseDown="RegenerationMapCell"/>
                    <Image x:Name="Image14" Grid.Row ="0" Grid.Column="3" MouseDown="RegenerationMapCell"/>
                    <Image x:Name="Image15" Grid.Row ="0" Grid.Column="4" MouseDown="RegenerationMapCell"/>
                    <Image x:Name="Image16" Grid.Row ="0" Grid.Column="5" MouseDown="RegenerationMapCell"/>

                    <Image x:Name="Image21" Grid.Row ="1" Grid.Column="0" MouseDown="RegenerationMapCell"/>
                    <Image x:Name="Image22" Grid.Row ="1" Grid.Column="1" MouseDown="RegenerationMapCell"/>
                    <Image x:Name="Image23" Grid.Row ="1" Grid.Column="2" MouseDown="RegenerationMapCell"/>
                    <Image x:Name="Image24" Grid.Row ="1" Grid.Column="3" MouseDown="RegenerationMapCell"/>
                    <Image x:Name="Image25" Grid.Row ="1" Grid.Column="4" MouseDown="RegenerationMapCell"/>
                    <Image x:Name="Image26" Grid.Row ="1" Grid.Column="5" MouseDown="RegenerationMapCell"/>

                    <Image x:Name="Image31" Grid.Row ="2" Grid.Column="0" MouseDown="RegenerationMapCell"/>
                    <Image x:Name="Image32" Grid.Row ="2" Grid.Column="1" MouseDown="RegenerationMapCell"/>
                    <Image x:Name="Image33" Grid.Row ="2" Grid.Column="2" MouseDown="RegenerationMapCell"/>
                    <Image x:Name="Image34" Grid.Row ="2" Grid.Column="3" MouseDown="RegenerationMapCell"/>
                    <Image x:Name="Image35" Grid.Row ="2" Grid.Column="4" MouseDown="RegenerationMapCell"/>
                    <Image x:Name="Image36" Grid.Row ="2" Grid.Column="5" MouseDown="RegenerationMapCell"/>

                    <Image x:Name="Image41" Grid.Row ="3" Grid.Column="0" MouseDown="RegenerationMapCell"/>
                    <Image x:Name="Image42" Grid.Row ="3" Grid.Column="1" MouseDown="RegenerationMapCell"/>
                    <Image x:Name="Image43" Grid.Row ="3" Grid.Column="2" MouseDown="RegenerationMapCell"/>
                    <Image x:Name="Image44" Grid.Row ="3" Grid.Column="3" MouseDown="RegenerationMapCell"/>
                    <Image x:Name="Image45" Grid.Row ="3" Grid.Column="4" MouseDown="RegenerationMapCell"/>
                    <Image x:Name="Image46" Grid.Row ="3" Grid.Column="5" MouseDown="RegenerationMapCell"/>

                    <Image x:Name="Image51" Grid.Row ="4" Grid.Column="0" MouseDown="RegenerationMapCell"/>
                    <Image x:Name="Image52" Grid.Row ="4" Grid.Column="1" MouseDown="RegenerationMapCell"/>
                    <Image x:Name="Image53" Grid.Row ="4" Grid.Column="2" MouseDown="RegenerationMapCell"/>
                    <Image x:Name="Image54" Grid.Row ="4" Grid.Column="3" MouseDown="RegenerationMapCell"/>
                    <Image x:Name="Image55" Grid.Row ="4" Grid.Column="4" MouseDown="RegenerationMapCell"/>
                    <Image x:Name="Image56" Grid.Row ="4" Grid.Column="5" MouseDown="RegenerationMapCell"/>

                    <Image x:Name="Image61" Grid.Row ="5" Grid.Column="0" MouseDown="RegenerationMapCell"/>
                    <Image x:Name="Image62" Grid.Row ="5" Grid.Column="1" MouseDown="RegenerationMapCell"/>
                    <Image x:Name="Image63" Grid.Row ="5" Grid.Column="2" MouseDown="RegenerationMapCell"/>
                    <Image x:Name="Image64" Grid.Row ="5" Grid.Column="3" MouseDown="RegenerationMapCell"/>
                    <Image x:Name="Image65" Grid.Row ="5" Grid.Column="4" MouseDown="RegenerationMapCell"/>
                    <Image x:Name="Image66" Grid.Row ="5" Grid.Column="5" MouseDown="RegenerationMapCell"/>
                </Grid>
            </Border>

            <TextBlock Grid.Row="1" TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="24" Text="Нажмите на ячейку для её перегенерации"/>
        </Grid>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>

            <Button Content="ГЕНЕРАЦИЯ" Grid.Row="1" Click="MapGeneration" FontSize="35"/>
            <Button Content="СОХРАНЕНИЕ" Grid.Row="3" Click="MapSaving" FontSize="35"/>
        </Grid>
    </Grid>
</Window>
